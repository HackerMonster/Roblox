-- Функция ТП к игроку (глобальная для кнопок выше)
function teleportToPlayer(name)
    local target = Players:FindFirstChild(name)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        teleport(
            target.Character.HumanoidRootPart.Position.X,
            target.Character.HumanoidRootPart.Position.Y + 2,
            target.Character.HumanoidRootPart.Position.Z
        )
    else
        -- Визуальное уведомление об ошибке (можно добавить Label)
        print("Игрок не найден: " .. name)
    end
end

