-- Пранки (Функции для других игроков)
local function getTarget(name)
    local target = Players:FindFirstChild(name)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        return target.Character
    end
    return nil
end

local function prankLift(name)
    local char = getTarget(name)
    if char then
        local root = char.HumanoidRootPart
        root.CFrame = root.CFrame * CFrame.new(0, 50, 0)
    end
end

local function prankDrop(name)
    local char = getTarget(name)
    if char then
        local root = char.HumanoidRootPart
        root.CFrame = root.CFrame * CFrame.new(0, -50, 0)
    end
end

local function prankThrow(name)
    local char = getTarget(name)
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.Velocity = Vector3.new(0, 100, 0)
    end
end

local function prankKill(name)
    local char = getTarget(name)
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.Health = 0
    end
end

-- СОЗДАНИЕ КНОПОК (Вспомогательная функция)
local function createButton(parent, text, callback, colorOverride)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = colorOverride or colors.btn    btn.TextColor3 = colors.main
    btn.Text = text
    btn.Font = Enum.Font.Code
    btn.TextSize = 14
    btn.AutoButtonColor = false
    
    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 6)
    
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = colors.stroke
    btnStroke.Thickness = 1
    btnStroke.Transparency = 0.6

    -- Анимация нажатия
    btn.MouseButton1Click:Connect(function()
        local tween = TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = colors.main, TextColor3 = colors.bg})
        tween:Play()
        tween.Completed:Wait()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = colorOverride or colors.btn, TextColor3 = colors.main}):Play()
        if callback then callback() end
    end)
    
    -- Ховер эффект
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = colors.btnHover}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = colorOverride or colors.btn}):Play()
    end)

    return btn
end

